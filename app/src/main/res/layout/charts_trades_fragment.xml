<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".Menu_CoinList">

        <LinearLayout
            android:id="@+id/linearLayout2"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">


            <com.google.android.material.appbar.AppBarLayout
                android:id="@+id/bar_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/darker_gray"
                android:gravity="top">

                <androidx.appcompat.widget.Toolbar
                    android:id="@+id/toolbar"
                    android:layout_width="wrap_content"
                    android:layout_height="21dp"
                    android:layout_gravity="center_horizontal"
                    android:background="@android:color/darker_gray"
                    android:textAlignment="center"
                    app:layout_scrollFlags="scroll|enterAlways"
                    app:popupTheme="@style/PopupOverlay"
                    app:title="Trades"
                    app:titleMargin="0dp"
                    app:titleTextAppearance="@style/TextAppearance.AppCompat.Small"
                    app:titleTextColor="@android:color/black" />


            </com.google.android.material.appbar.AppBarLayout>

            <TableLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TableRow
                    android:id="@+id/Cabecera"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="2dp"
                    tools:ignore="UselessParent">

                    <TextView
                        android:id="@+id/trade_date"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_margin="0dp"
                        android:layout_marginHorizontal="10dp"
                        android:layout_weight="18"
                        android:background="@drawable/border"
                        android:fontFamily="sans-serif"
                        android:text="@string/date"
                        android:textAlignment="center"
                        android:textColor="#A9ACA9"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/trade_price"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_margin="0dp"
                        android:layout_marginHorizontal="10dp"
                        android:layout_weight="30"
                        android:background="@drawable/border"
                        android:fontFamily="sans-serif"
                        android:text="@string/price"
                        android:textAlignment="center"
                        android:textColor="#A9ACA9"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/trade_items"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_margin="0dp"
                        android:layout_marginHorizontal="10dp"
                        android:layout_weight="25"
                        android:background="@drawable/border"
                        android:fontFamily="sans-serif"
                        android:text="@string/qty"
                        android:textAlignment="center"
                        android:textColor="#A9ACA9"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/trades_btc"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_margin="0dp"
                        android:layout_marginHorizontal="10dp"
                        android:layout_weight="27"
                        android:background="@drawable/border"
                        android:fontFamily="sans-serif"
                        android:text="@string/btc_eq"
                        android:textAlignment="center"
                        android:textColor="#A9ACA9"
                        android:textSize="14sp" />

                </TableRow>
            </TableLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/orders"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scrollbarThumbVertical="@drawable/scrollbar"
                android:scrollbars="vertical"
                android:verticalScrollbarPosition="right"
                app:layout_anchorGravity="end"
                tools:listitem="@layout/items_trades_extended">

            </androidx.recyclerview.widget.RecyclerView>


        </LinearLayout>

    </androidx.coordinatorlayout.widget.CoordinatorLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
